# Copy to server/.env.test and adjust. Run with: npm run start:test (after npm run build)
NODE_ENV=test
PORT=5001
MONGODB_URI=mongodb://localhost:27017/niat_insider_test
JWT_SECRET=your_test_secret_here
JWT_EXPIRES_IN=1d
# Comma-separated origins (Vite default + CRA-style). No spaces after commas optional.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
